# Server
HOST=127.0.0.1
PORT=8600

# Instagram OAuth (from Meta Developer App → Instagram product)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8600/api/auth/instagram/callback

# AI Provider
ANTHROPIC_API_KEY=

# Google Drive (for image hosting when publishing)
GOOGLE_DRIVE_CREDENTIALS_FILE=
GOOGLE_DRIVE_FOLDER_ID=

# Encryption key for stored tokens (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=
